^\.git\/
^\.github\/
^\.gitmodules$
^\.gitignore$

^tools\/

# Makemaker generated files and dirs.
^MANIFEST\.
^Makefile$
^blib/
^MakeMaker-\d
^MYMETA\..*
^pm_to_blib$

# Module specific files
\bConfig-INI-RefVar-\d+(?:\.\d+)+\/
^Config-INI-RefVars-\d+(?:\.\d+)+\.tar\.gz$

# Temp, old and emacs backup files.
~$
\.old$
(?:^|/)#[^/]*#$
(?:^|/)\.#

# We generate a README file for the distribution, so README.md is not needed.
^README\.md$

# Other
^tmp.*
